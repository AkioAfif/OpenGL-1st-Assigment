{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build OpenGL",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "src/main.cpp",
                "src/glad.c",
                "-Iinclude",
                "-Llib",
                "-lglfw3dll",
                "-lopengl32",
                "-lgdi32",
                "-o",
                "main.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Run OpenGL",
            "type": "shell",
            "command": ".\\main.exe",
            "dependsOn": "Build OpenGL",
            "group": "test",
            "problemMatcher": []
        }
    ]
}
