{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build OpenGL",
            "command": "g++",
            "args": [
                "-g",
                "-std=c++17",
                "-Wall",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/glad.c",
                "-I${workspaceFolder}/include",
                "-I${workspaceFolder}/include/glm",
                "-L${workspaceFolder}/lib",
                "-lglfw3dll",
                "-lopengl32",
                "-lgdi32",
                "-o",
                "${workspaceFolder}/main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build OpenGL assignment"
        },
        {
            "label": "Run OpenGL",
            "type": "shell",
            "command": "${workspaceFolder}\\main.exe",
            "dependsOn": "Build OpenGL",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
